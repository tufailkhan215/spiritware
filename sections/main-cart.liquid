{% comment %}
  Cart page section – full cart with line items, quantity updates, remove, checkout.
{% endcomment %}

<div class="main-cart section" data-section-id="{{ section.id }}">
  <div class="main-cart__inner">
    <h1 class="main-cart__title">{{ section.settings.heading | default: 'Your cart' }}</h1>

    {%- if cart.item_count == 0 -%}
      <div class="main-cart__empty">
        <p>{{ section.settings.empty_message | default: 'Your cart is empty.' }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="main-cart__continue">{{ section.settings.continue_message | default: 'Continue shopping' }}</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" id="CartForm" class="main-cart__form">
        <div class="main-cart__items">
          {%- for item in cart.items -%}
            <div class="main-cart__item" data-key="{{ item.key }}">
              <div class="main-cart__item-image">
                {%- if item.image != blank -%}
                  <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.image.alt | escape }}" width="120" height="120" loading="lazy">
                {%- else -%}
                  <span class="main-cart__item-placeholder">No image</span>
                {%- endif -%}
              </div>
              <div class="main-cart__item-details">
                <a href="{{ item.url }}" class="main-cart__item-title">{{ item.product.title }}</a>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p class="main-cart__item-variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="main-cart__item-price">{{ item.final_line_price | money }}</p>
                <div class="main-cart__item-quantity">
                  <label for="updates_{{ item.key }}" class="visually-hidden">Quantity for {{ item.product.title }}</label>
                  <input
                    type="number"
                    name="updates[]"
                    id="updates_{{ item.key }}"
                    value="{{ item.quantity }}"
                    min="0"
                    class="main-cart__qty-input"
                    aria-label="Quantity for {{ item.product.title }}"
                  >
                </div>
                <a href="{{ item.url_to_remove }}" class="main-cart__remove" aria-label="{{ 'sections.cart.remove' | t | default: 'Remove' }} {{ item.product.title }}">{{ 'sections.cart.remove' | t | default: 'Remove' }}</a>
              </div>
            </div>
          {%- endfor -%}
        </div>
        <div class="main-cart__footer">
          <div class="main-cart__total">
            <span>{{ 'sections.cart.subtotal' | t | default: 'Subtotal' }}</span>
            <span class="main-cart__total-price">{{ cart.total_price | money }}</span>
          </div>
          <p class="main-cart__note">{{ 'sections.cart.taxes_and_shipping_at_checkout' | t | default: 'Taxes and shipping calculated at checkout' }}</p>
          <button type="submit" name="update" class="main-cart__update-btn">{{ 'sections.cart.update' | t | default: 'Update cart' }}</button>
          <a href="/checkout" class="main-cart__checkout-btn button">{{ section.settings.checkout_label | default: 'Checkout' }}</a>
          <a href="{{ routes.all_products_collection_url }}" class="main-cart__continue-link">{{ section.settings.continue_message | default: 'Continue shopping' }}</a>
        </div>
      </form>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your cart"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Empty cart message",
      "default": "Your cart is empty."
    },
    {
      "type": "text",
      "id": "continue_message",
      "label": "Continue shopping text",
      "default": "Continue shopping"
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "Checkout button text",
      "default": "Checkout"
    }
  ]
}
{% endschema %}
