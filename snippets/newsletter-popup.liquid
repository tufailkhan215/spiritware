{% liquid
  assign popup_enabled = settings.newsletter_popup_enable
%}

{% if popup_enabled %}
  <div class="newsletter-popup-overlay" data-newsletter-popup-overlay
    data-success-heading="{{ settings.newsletter_popup_success_heading | escape }}"
    data-success-message="{{ settings.newsletter_popup_success_message | escape }}">
    <div class="newsletter-popup">
      <button class="newsletter-popup-close" type="button" aria-label="Close" data-newsletter-popup-close>&times;</button>

      <div class="newsletter-popup-inner">
        <div class="newsletter-popup-content">
          <div id="NewsletterPopupIntro" data-newsletter-popup-intro>
            {% if settings.newsletter_popup_badge != blank %}
              <p class="newsletter-popup-badge">
                {{ settings.newsletter_popup_badge }}
              </p>
            {% endif %}

            {% if settings.newsletter_popup_heading != blank %}
              <h2 class="newsletter-popup-heading">
                {{ settings.newsletter_popup_heading }}
              </h2>
            {% endif %}

            {% if settings.newsletter_popup_subtext != blank %}
              <p class="newsletter-popup-subtext">
                {{ settings.newsletter_popup_subtext }}
              </p>
            {% endif %}
          </div>

          <div id="NewsletterPopupFormWrapper" data-newsletter-popup-form-wrapper>
            {% form 'customer', id: 'NewsletterPopupForm' %}
              <div class="newsletter-popup-message newsletter-popup-message--error" id="NewsletterPopupFormError" style="display: none;"></div>

              <input type="hidden" name="contact[tags]" value="newsletter">

              <div class="newsletter-popup-fields">
                <div class="newsletter-popup-field">
                  <label class="newsletter-popup-label" for="NewsletterPopupFirstName">
                    {{ settings.newsletter_popup_first_name_label | default: 'First name' }}
                  </label>
                  <input
                    id="NewsletterPopupFirstName"
                    class="newsletter-popup-input"
                    type="text"
                    name="contact[first_name]"
                    autocomplete="given-name"
                  >
                </div>

                <div class="newsletter-popup-field">
                  <label class="newsletter-popup-label" for="NewsletterPopupEmail">
                    {{ settings.newsletter_popup_email_label | default: 'Email' }}
                  </label>
                  <input
                    id="NewsletterPopupEmail"
                    class="newsletter-popup-input"
                    type="email"
                    name="contact[email]"
                    autocomplete="email"
                    required
                  >
                </div>
              </div>

              <button class="newsletter-popup-button" type="submit" id="NewsletterPopupSubmitBtn" data-original-text="{{ settings.newsletter_popup_button_label | default: 'Unlock your discount' | escape }}">
                {{ settings.newsletter_popup_button_label | default: 'Unlock your discount' }}
              </button>

              {% if settings.newsletter_popup_disclaimer != blank %}
                <p class="newsletter-popup-disclaimer">
                  {{ settings.newsletter_popup_disclaimer }}
                </p>
              {% endif %}
            {% endform %}
          </div>

          <div class="newsletter-popup-success" id="NewsletterPopupSuccess" data-newsletter-popup-success style="display: none;">
            <h2 class="newsletter-popup-success-heading" id="NewsletterPopupSuccessHeading"></h2>
            <p class="newsletter-popup-success-message" id="NewsletterPopupSuccessMessage"></p>
          </div>
        </div>

        {% if settings.newsletter_popup_image != blank %}
          <div class="newsletter-popup-image-wrapper">
            <img
              class="newsletter-popup-image"
              src="{{ settings.newsletter_popup_image | image_url: width: 800 }}"
              alt="{{ settings.newsletter_popup_heading | escape }}"
              loading="lazy"
            >
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <script>
    (function() {
      var enabled = {{ settings.newsletter_popup_enable | json }};
      if (!enabled) return;

      var delaySeconds = {{ settings.newsletter_popup_delay | default: 5 | json }};
      var overlay = document.querySelector('[data-newsletter-popup-overlay]');
      if (!overlay) return;

      var CLOSE_KEY = 'newsletter_popup_closed_v1';
      if (window.localStorage && localStorage.getItem(CLOSE_KEY) === 'true') {
        return;
      }

      function openPopup() {
        overlay.classList.add('newsletter-popup-overlay--visible');
        var emailInput = overlay.querySelector('#NewsletterPopupEmail');
        if (emailInput) {
          emailInput.focus();
        }
      }

      function closePopup() {
        overlay.classList.remove('newsletter-popup-overlay--visible');
        if (window.localStorage) {
          localStorage.setItem(CLOSE_KEY, 'true');
        }
      }

      document.addEventListener('click', function(event) {
        if (event.target.matches('[data-newsletter-popup-close]')) {
          event.preventDefault();
          closePopup();
        }

        if (event.target === overlay) {
          closePopup();
        }
      });

      var form = document.getElementById('NewsletterPopupForm');
      var formWrapper = document.getElementById('NewsletterPopupFormWrapper');
      var successBlock = document.getElementById('NewsletterPopupSuccess');
      var successHeadingEl = document.getElementById('NewsletterPopupSuccessHeading');
      var successMessageEl = document.getElementById('NewsletterPopupSuccessMessage');
      var errorEl = document.getElementById('NewsletterPopupFormError');
      var submitBtn = document.getElementById('NewsletterPopupSubmitBtn');

      function showSuccess() {
        var overlay = document.querySelector('[data-newsletter-popup-overlay]');
        var heading = overlay.getAttribute('data-success-heading') || 'Thank you!';
        var message = overlay.getAttribute('data-success-message') || 'Check your inbox for your coupon.';
        var intro = document.getElementById('NewsletterPopupIntro');
        if (intro) intro.style.display = 'none';
        if (formWrapper) formWrapper.style.display = 'none';
        if (successBlock) {
          if (successHeadingEl) successHeadingEl.textContent = heading;
          if (successMessageEl) successMessageEl.textContent = message;
          successBlock.style.display = 'block';
        }
        if (window.localStorage) localStorage.setItem(CLOSE_KEY, 'true');
      }

      function showError(msg) {
        if (errorEl) {
          errorEl.textContent = msg || 'Something went wrong. Please try again.';
          errorEl.style.display = 'block';
        }
      }

      function hideError() {
        if (errorEl) errorEl.style.display = 'none';
      }

      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          e.stopPropagation();
          hideError();
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = submitBtn.getAttribute('data-loading-text') || 'Sending...';
          }
          var formData = new FormData(form);
          if (!formData.has('form_type')) formData.append('form_type', 'customer');
          var action = form.getAttribute('action') || '/contact#contact_form';
          if (action.indexOf('#') !== -1) action = action.split('#')[0];
          var body = new URLSearchParams(formData).toString();

          fetch(action, {
            method: 'POST',
            body: body,
            redirect: 'manual',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
              'X-Requested-With': 'XMLHttpRequest',
              'Accept': 'text/html'
            }
          }).then(function(res) {
            if (res.type === 'opaqueredirect' || res.status === 0 || res.status === 302 || res.status === 303) {
              showSuccess();
              return;
            }
            if (res.status === 429) {
              showError('Too many attempts. Please try again in a few minutes.');
              return;
            }
            if (res.status === 400) {
              showError('Something went wrong. Please try again.');
              return;
            }
            if (res.ok) {
              return res.text().then(function(html) {
                if (!html) { showError('Something went wrong. Please try again.'); return; }
                var isSuccess = html.indexOf('form-posted-successfully') !== -1 || html.indexOf('form-success') !== -1;
                if (isSuccess) showSuccess();
                else showError('Something went wrong. Please try again.');
              }).catch(function() { showError('Something went wrong. Please try again.'); });
            } else {
              showError('Something went wrong. Please try again.');
            }
          }).catch(function() {
            showError('Something went wrong. Please try again.');
          }).then(function() {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = submitBtn.getAttribute('data-original-text') || 'Unlock your discount';
            }
          });
          return false;
        }, false);
      }

      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && overlay.classList.contains('newsletter-popup-overlay--visible')) {
          closePopup();
        }
      });

      document.addEventListener('DOMContentLoaded', function() {
        setTimeout(openPopup, Math.max(0, delaySeconds) * 1000);
      });
    })();
  </script>
{% endif %}

