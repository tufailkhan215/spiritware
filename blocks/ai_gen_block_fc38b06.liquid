{% doc %}
  @prompt
    attach a video that autoplays , need the video to be uploaed on here not a vudeo url
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-block-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: #000000;
  }

  .ai-video-wrapper-{{ ai_gen_id }}::before {
    content: '';
    display: block;
    padding-top: {{ block.settings.aspect_ratio }}%;
  }

  .ai-video-element-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    display: flex;
    gap: 10px;
    z-index: 2;
  }

  .ai-video-control-btn-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(0, 0, 0, 0.6);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: background-color 0.3s ease;
  }

  .ai-video-control-btn-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.8);
  }

  .ai-video-control-btn-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-video-block-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-video-controls-{{ ai_gen_id }} {
      bottom: 10px;
      right: 10px;
    }

    .ai-video-control-btn-{{ ai_gen_id }} {
      width: 36px;
      height: 36px;
    }
  }
{% endstyle %}

<autoplay-video-{{ ai_gen_id }} class="ai-video-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video != blank %}
      {% assign video_sources = block.settings.video.sources %}
      <video
        class="ai-video-element-{{ ai_gen_id }}"
        autoplay
        {% if block.settings.loop_video %}loop{% endif %}
        {% if block.settings.mute_video %}muted{% endif %}
        playsinline
        {% unless block.settings.show_controls %}
          controlslist="nodownload nofullscreen noremoteplayback"
        {% endunless %}
      >
        {% for source in video_sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
        Your browser does not support the video tag.
      </video>

      {% if block.settings.show_custom_controls %}
        <div class="ai-video-controls-{{ ai_gen_id }}">
          <button
            class="ai-video-control-btn-{{ ai_gen_id }} ai-video-play-pause-{{ ai_gen_id }}"
            aria-label="Play or pause video"
          >
            <svg class="ai-video-pause-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="4" width="4" height="16"></rect>
              <rect x="14" y="4" width="4" height="16"></rect>
            </svg>
            <svg class="ai-video-play-icon-{{ ai_gen_id }}" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
          </button>

          <button
            class="ai-video-control-btn-{{ ai_gen_id }} ai-video-mute-{{ ai_gen_id }}"
            aria-label="Mute or unmute video"
          >
            <svg class="ai-video-unmute-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
            </svg>
            <svg class="ai-video-mute-icon-{{ ai_gen_id }}" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <line x1="23" y1="9" x2="17" y2="15"></line>
              <line x1="17" y1="9" x2="23" y2="15"></line>
            </svg>
          </button>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-video-placeholder-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
        <div class="ai-video-empty-state-{{ ai_gen_id }}">
          Next, upload a video
        </div>
      </div>
    {% endif %}
  </div>
</autoplay-video-{{ ai_gen_id }}>

<script>
  (function() {
    class AutoplayVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-video-element-{{ ai_gen_id }}');
        this.playPauseBtn = this.querySelector('.ai-video-play-pause-{{ ai_gen_id }}');
        this.muteBtn = this.querySelector('.ai-video-mute-{{ ai_gen_id }}');
        this.playIcon = this.querySelector('.ai-video-play-icon-{{ ai_gen_id }}');
        this.pauseIcon = this.querySelector('.ai-video-pause-icon-{{ ai_gen_id }}');
        this.muteIcon = this.querySelector('.ai-video-mute-icon-{{ ai_gen_id }}');
        this.unmuteIcon = this.querySelector('.ai-video-unmute-icon-{{ ai_gen_id }}');

        if (!this.video) return;

        this.setupEventListeners();
        this.updateMuteIcon();
      }

      setupEventListeners() {
        if (this.playPauseBtn) {
          this.playPauseBtn.addEventListener('click', () => {
            if (this.video.paused) {
              this.video.play();
              this.updatePlayPauseIcon(false);
            } else {
              this.video.pause();
              this.updatePlayPauseIcon(true);
            }
          });
        }

        if (this.muteBtn) {
          this.muteBtn.addEventListener('click', () => {
            this.video.muted = !this.video.muted;
            this.updateMuteIcon();
          });
        }

        this.video.addEventListener('play', () => {
          this.updatePlayPauseIcon(false);
        });

        this.video.addEventListener('pause', () => {
          this.updatePlayPauseIcon(true);
        });
      }

      updatePlayPauseIcon(isPaused) {
        if (!this.playIcon || !this.pauseIcon) return;

        if (isPaused) {
          this.playIcon.style.display = 'block';
          this.pauseIcon.style.display = 'none';
        } else {
          this.playIcon.style.display = 'none';
          this.pauseIcon.style.display = 'block';
        }
      }

      updateMuteIcon() {
        if (!this.muteIcon || !this.unmuteIcon) return;

        if (this.video.muted) {
          this.muteIcon.style.display = 'block';
          this.unmuteIcon.style.display = 'none';
        } else {
          this.muteIcon.style.display = 'none';
          this.unmuteIcon.style.display = 'block';
        }
      }
    }

    customElements.define('autoplay-video-{{ ai_gen_id }}', AutoplayVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Autoplay video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "56.25",
          "label": "16:9"
        },
        {
          "value": "75",
          "label": "4:3"
        },
        {
          "value": "100",
          "label": "1:1"
        },
        {
          "value": "125",
          "label": "4:5"
        },
        {
          "value": "177.78",
          "label": "9:16"
        }
      ],
      "default": "56.25"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Playback"
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mute_video",
      "label": "Mute video",
      "default": true,
      "info": "Most browsers require videos to be muted for autoplay"
    },
    {
      "type": "checkbox",
      "id": "show_custom_controls",
      "label": "Show custom controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show native browser controls",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Autoplay video"
    }
  ]
}
{% endschema %}
